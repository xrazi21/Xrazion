rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default global deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Help primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to evaluate admins of the platform
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 1. User Profile validation gate
    function isValidUserProfile(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.avatar is string && data.avatar.size() <= 500
        && data.coins is int && data.coins >= 0
        && data.diamonds is int && data.diamonds >= 0
        && data.level is int && data.level >= 0
        && data.vip is bool
        && data.country is string && data.country.size() <= 100
        && (data.gender == 'Male' || data.gender == 'Female' || data.gender == 'Other')
        && data.bio is string && data.bio.size() <= 500
        && data.verified is bool;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      
      // Transactions subcollection
      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(request.resource.data);
      }
    }

    // 3. Transactions Schema Validation helper
    function isValidTransaction(data) {
      return data.id is string && data.id.size() <= 128
        && (data.type == 'buy_coin' || data.type == 'send_gift' || data.type == 'vip_purchase' || data.type == 'withdraw')
        && data.amount is int && data.amount >= 0
        && data.description is string && data.description.size() <= 200
        && data.timestamp is string && data.timestamp.size() <= 100
        && (data.status == 'Success' || data.status == 'Pending' || data.status == 'Failed');
    }

    // 4. Reports validation helper
    function isValidReport(data) {
      return data.id is string && data.id.size() <= 128
        && data.reportedHostId is string && data.reportedHostId.size() <= 128
        && data.reportedHostName is string && data.reportedHostName.size() <= 100
        && data.reason is string && data.reason.size() <= 500
        && data.timestamp is string && data.timestamp.size() <= 100
        && data.status == 'Pending';
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(request.resource.data);
      allow get, list: if isAdmin();
      allow update: if isAdmin() && request.resource.data.status in ['Reviewed', 'Dismissed'];
    }
  }
}
